    M5.Display.print("-");
    M5.Display.setTextSize(3); M5.Display.setTextColor(COL_HEAT);
    M5.Display.setCursor(DL.col1 + bW + 10, DL.yHeatAdj + DL.btnH/2 - 12);
    M5.Display.printf("%.1f", rm.heatTarget);
    M5.Display.setTextSize(2); M5.Display.print("C");
    int plusX = DL.col1 + bW + 90;
    M5.Display.fillRoundRect(plusX, DL.yHeatAdj, bW, DL.btnH, 8, COL_DARK_GREY);
    M5.Display.drawRoundRect(plusX, DL.yHeatAdj, bW, DL.btnH, 8, COL_GREY);
    M5.Display.setTextSize(3); M5.Display.setTextColor(COL_WHITE);
    M5.Display.setCursor(plusX + bW/2 - 9, DL.yHeatAdj + DL.btnH/2 - 12);
    M5.Display.print("+");
  }

  // ── Volet ──
  if (rm.shutterPos >= 0) {
    M5.Display.setTextSize(2); M5.Display.setTextColor(COL_ORANGE);
    M5.Display.setCursor(DL.col1, DL.yShutLabel);
    M5.Display.printf("VOLET  %d%%", rm.shutterPos);
    int bW3 = (DL.colW - 8) / 3;
    const char* lbls[3] = {"Ferme", "Mi", "Ouvert"};
    int vals[3] = {0, 50, 100};
    for (int b = 0; b < 3; b++) {
      int bx = DL.col1 + b * (bW3 + 4);
      bool active = (rm.shutterPos == vals[b]);
      M5.Display.fillRoundRect(bx, DL.yShutBtns, bW3, DL.btnH, 8,
                               active ? COL_BLUE : COL_DARK_GREY);
      M5.Display.drawRoundRect(bx, DL.yShutBtns, bW3, DL.btnH, 8,
                               active ? COL_BLUE : COL_GREY);
      M5.Display.setTextSize(2);
      M5.Display.setTextColor(active ? 0x0000 : COL_GREY);
      int tw = strlen(lbls[b]) * 12;
      M5.Display.setCursor(bx + bW3/2 - tw/2, DL.yShutBtns + DL.btnH/2 - 8);
      M5.Display.print(lbls[b]);
    }
    int sw = DL.colW - 50;
    M5.Display.fillRoundRect(DL.col1, DL.yShutBar, sw, DL.barH, 6, COL_DARK_GREY);
    int sfw = sw * rm.shutterPos / 100;
    if (sfw > 0) M5.Display.fillRoundRect(DL.col1, DL.yShutBar, sfw, DL.barH, 6,
                                          rm.shutterMoving ? COL_ORANGE : COL_BLUE);
    if (sfw > 2) M5.Display.drawFastVLine(DL.col1 + sfw - 1, DL.yShutBar - 2, DL.barH + 4, COL_WHITE);
  }

  // ── Fenêtre ──
  if (rm.hasWindow) {
    M5.Display.setTextSize(2); M5.Display.setTextColor(COL_ORANGE);
    M5.Display.setCursor(DL.col2, DL.yWinLabel);
    M5.Display.print("FENETRE");
    uint16_t wc = rm.windowOpen ? COL_WIND : COL_DARK_GREY;
    M5.Display.fillRoundRect(DL.col2, DL.yWinLabel + 22, DL.colW, DL.btnH, 8, wc);
    M5.Display.setTextSize(3);
    M5.Display.setTextColor(rm.windowOpen ? 0x0000 : COL_GREY);
    const char* wlbl = rm.windowOpen ? "Ouverte" : "Fermee";
    int tw = strlen(wlbl) * 18;
    M5.Display.setCursor(DL.col2 + DL.colW/2 - tw/2,
                         DL.yWinLabel + 22 + DL.btnH/2 - 12);
    M5.Display.print(wlbl);
    M5.Display.setTextSize(1); M5.Display.setTextColor(COL_GREY);
    M5.Display.setCursor(DL.col2, DL.yWinLabel + 22 + DL.btnH + 6);
    M5.Display.print("(capteur automatique)");
  }

  // ── Capteurs ──
  M5.Display.setTextSize(2); M5.Display.setTextColor(COL_ORANGE);
  M5.Display.setCursor(DL.col2, DL.yDHTLabel);
  M5.Display.print("CAPTEURS");
  if (rm.hasDHT && rm.temp > 0) {
    M5.Display.setTextSize(4); M5.Display.setTextColor(COL_TEAL);
    M5.Display.setCursor(DL.col2, DL.yDHTLabel + 22);
    M5.Display.printf("%.1f", rm.temp);
    M5.Display.setTextSize(2); M5.Display.setTextColor(COL_GREY);
    M5.Display.print("C");
    M5.Display.setTextSize(3);
    M5.Display.setTextColor(rm.humidity > 65 ? COL_YELLOW : COL_GREY);
    M5.Display.setCursor(DL.col2, DL.yDHTLabel + 62);
    M5.Display.printf("%.0f%%", rm.humidity);
  } else if (rm.hasDHT) {
    M5.Display.setTextSize(3); M5.Display.setTextColor(COL_DARK_GREY);
    M5.Display.setCursor(DL.col2, DL.yDHTLabel + 22);
    M5.Display.print("--.-C");
    M5.Display.setCursor(DL.col2, DL.yDHTLabel + 62);
    M5.Display.print("--%");
  }

  // ── Mouvement ──
  if (rm.hasPIR) {
    bool motion = rm.motionDetected && millis() - rm.motionLastSeen < MOTION_ALERT_MS;
    M5.Display.setTextSize(2); M5.Display.setTextColor(COL_ORANGE);
    M5.Display.setCursor(DL.col2, DL.yMotionBadge);
    M5.Display.print("MOUVEMENT");
    uint16_t mc = motion ? COL_RED : 0x2924;
    M5.Display.fillRoundRect(DL.col2, DL.yMotionBadge + 22, DL.colW, DL.btnH, 8, mc);
    M5.Display.drawRoundRect(DL.col2, DL.yMotionBadge + 22, DL.colW, DL.btnH, 8,
                             motion ? COL_RED : COL_BORDER);
    M5.Display.setTextSize(2);
    M5.Display.setTextColor(motion ? COL_WHITE : COL_DARK_GREY);
    const char* mlbl = motion ? "! DETECTE !" : "---";
    int tw = strlen(mlbl) * 12;
    M5.Display.setCursor(DL.col2 + DL.colW/2 - tw/2,
                         DL.yMotionBadge + 22 + DL.btnH/2 - 8);
    M5.Display.print(mlbl);
  }
}

// ─── TACTILE GRILLE ───────────────────────────────────────────
void handleTouchGrid() {
  auto touch = M5.Touch.getDetail();
  if (!touch.wasPressed()) return;
  int tx = touch.x, ty = touch.y;
  for (int i = 0; i < NUM_ROOMS; i++) {
    Rect r = cardRects[i];
    if (tx >= r.x && tx < r.x+r.w && ty >= r.y && ty < r.y+r.h) {
      selectedRoom = i;
      currentView  = VIEW_DETAIL;
      M5.Display.fillScreen(COL_BG);
      drawHeader();
      drawDetailView(i);
      return;
    }
  }
}

// ─── TACTILE DÉTAIL ───────────────────────────────────────────
void handleTouchDetail() {
  auto touch = M5.Touch.getDetail();
  Room& rm = rooms[selectedRoom];

  if (touch.wasPressed()) {
    int tx = touch.x, ty = touch.y;

    // Retour
    if (tx >= SCR_W-110 && ty >= 4 && ty <= HDR_H-4) {
      currentView = VIEW_GRID;
      M5.Display.fillScreen(COL_BG);
      drawHeader(); drawGrid();
      return;
    }
    // Toggle lumière
    if (tx >= DL.col1 && tx <= DL.col1+DL.colW &&
        ty >= DL.yLightBtn && ty <= DL.yLightBtn+DL.btnH) {
      rm.lightOn = !rm.lightOn;
      publishLight(selectedRoom);
      drawDetailView(selectedRoom); drawHeader();
      return;
    }
    // Toggle chauffage
    if (rm.hasHeat &&
        tx >= DL.col1 && tx <= DL.col1+DL.colW &&
        ty >= DL.yHeatBtn && ty <= DL.yHeatBtn+DL.btnH) {
      rm.heatOn = !rm.heatOn;
      publishHeat(selectedRoom);
      drawDetailView(selectedRoom);
      return;
    }
    // Bouton − consigne
    if (rm.hasHeat &&
        tx >= DL.col1 && tx <= DL.col1+52 &&
        ty >= DL.yHeatAdj && ty <= DL.yHeatAdj+DL.btnH) {
      rm.heatTarget = max(10.0f, rm.heatTarget - 0.5f);
      publishHeat(selectedRoom);
      drawDetailView(selectedRoom);
      return;
    }
    // Bouton + consigne
    if (rm.hasHeat &&
        tx >= DL.col1+52+90 && tx <= DL.col1+52+90+52 &&
        ty >= DL.yHeatAdj && ty <= DL.yHeatAdj+DL.btnH) {
      rm.heatTarget = min(30.0f, rm.heatTarget + 0.5f);
      publishHeat(selectedRoom);
      drawDetailView(selectedRoom);
      return;
    }
    // 3 boutons volet
    if (rm.shutterPos >= 0) {
      int bW3 = (DL.colW - 8) / 3;
      int vals[3] = {0, 50, 100};
      for (int b = 0; b < 3; b++) {
        int bx = DL.col1 + b * (bW3 + 4);
        if (tx >= bx && tx <= bx+bW3 &&
            ty >= DL.yShutBtns && ty <= DL.yShutBtns+DL.btnH) {
          rm.shutterPos = vals[b];
          publishShutter(selectedRoom);
          drawDetailView(selectedRoom);
          return;
        }
      }
    }
  }

  // Sliders
  if (touch.isPressed()) {
    int tx = touch.x, ty = touch.y;
    int bw = DL.colW - 50;
    // Slider brightness
    if (tx >= DL.col1 && tx <= DL.col1+bw &&
        ty >= DL.yBriBar-4 && ty <= DL.yBriBar+DL.barH+4) {
      int newBri = constrain((tx-DL.col1)*100/bw, 0, 100);
      if (newBri != rm.brightness) {
        rm.brightness = newBri;
        if (millis()-lastSliderPub > SLIDER_PUB_MS) {
          publishLight(selectedRoom); lastSliderPub = millis();
        }
        drawDetailView(selectedRoom);
      }
      return;
    }
    // Slider volet
    if (rm.shutterPos >= 0) {
      int sw = DL.colW - 50;
      if (tx >= DL.col1 && tx <= DL.col1+sw &&
          ty >= DL.yShutBar-4 && ty <= DL.yShutBar+DL.barH+4) {
        int newPos = constrain((tx-DL.col1)*100/sw, 0, 100);
        if (newPos != rm.shutterPos) {
          rm.shutterPos = newPos;
          if (millis()-lastSliderPub > SLIDER_PUB_MS) {
            publishShutter(selectedRoom); lastSliderPub = millis();
          }
          drawDetailView(selectedRoom);
        }
        return;
      }
    }
  }
}

// ─── SETUP ────────────────────────────────────────────────────
void setup() {
  Serial.begin(115200);
  delay(300);
  auto cfg = M5.config();
  M5.begin(cfg);
  M5.Display.setRotation(1);
  computeLayout();
  computeDetailLayout();

  M5.Display.fillScreen(COL_BG);
  M5.Display.setTextSize(3);
  M5.Display.setTextColor(COL_ORANGE);
  M5.Display.setCursor(20, SCR_H/2 - 50);
  M5.Display.print("SMART HOME");
  M5.Display.setTextSize(2);
  M5.Display.setTextColor(COL_GREY);
  M5.Display.setCursor(20, SCR_H/2);
  M5.Display.print("Connexion WiFi...");

  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  int r = 0;
  while (WiFi.status() != WL_CONNECTED && r < 40) { delay(500); r++; }

  configTime(3600, 3600, "pool.ntp.org");
  wifiClient.setCACert(HIVEMQ_CA_CERT);

  M5.Display.setCursor(20, SCR_H/2 + 30);
  M5.Display.print("MQTT TLS...");
  mqttConnect();

  if (mqttConnected) {
    M5.Display.setTextColor(COL_GREEN);
    M5.Display.setCursor(20, SCR_H/2 + 60);
    M5.Display.print("Connecte !");
  }
  delay(600);
  drawHeader();
  drawGrid();
}

// ─── LOOP ─────────────────────────────────────────────────────
void loop() {
  M5.update();

  if (!mqttClient.connected()) {
    mqttConnected = false;
    if (millis() - lastReconnect > 5000) {
      lastReconnect = millis();
      mqttConnect();
      drawHeader();
    }
  }
  mqttClient.loop();

  if (currentView == VIEW_GRID)   handleTouchGrid();
  else                            handleTouchDetail();

  if (needRedraw) {
    needRedraw = false;
    if (currentView == VIEW_GRID) drawGrid();
    else drawDetailView(selectedRoom);
    drawHeader();
  }

  static uint32_t lastCheck = 0;
  if (millis() - lastCheck > 1000) {
    lastCheck = millis();
    bool changed = false;
    for (int i = 0; i < NUM_ROOMS; i++) {
      if (rooms[i].motionDetected &&
          millis() - rooms[i].motionLastSeen > MOTION_ALERT_MS) {
        rooms[i].motionDetected = false;
        changed = true;
      }
    }
    if (changed && currentView == VIEW_GRID) drawGrid();
  }
}
