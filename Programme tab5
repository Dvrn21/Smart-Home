// ─── CARTE GRILLE ─────────────────────────────────────────────
void drawRoomCard(int idx) {
  Rect  r  = cardRects[idx];
  Room& rm = rooms[idx];
  if (rm.motionDetected && millis() - rm.motionLastSeen > MOTION_ALERT_MS)
    rm.motionDetected = false;
  uint16_t bg   = rm.lightOn ? COL_GREEN_DARK : COL_CARD;
  uint16_t bord = rm.motionDetected ? COL_RED :
                  rm.lightOn        ? COL_GREEN : COL_BORDER;
  M5.Display.fillRect(r.x, r.y, r.w, r.h, bg);
  M5.Display.drawRect(r.x, r.y, r.w, r.h, bord);
  int pad = max(5, CARD_W / 28);
  int cy  = r.y + CARD_H / 2;
  M5.Display.setTextSize(2);
  M5.Display.setTextColor(COL_WHITE);
  M5.Display.setCursor(r.x + pad, r.y + 6);
  M5.Display.print(rm.label);
  uint16_t lc = rm.lightOn ? COL_YELLOW : COL_DARK_GREY;
  M5.Display.fillCircle(r.x + pad + 7, cy - 2, 7, lc);
  M5.Display.setTextSize(1);
  M5.Display.setTextColor(rm.lightOn ? COL_YELLOW : COL_GREY);
  M5.Display.setCursor(r.x + pad + 18, cy - 6);
  M5.Display.print(rm.lightOn ? "ON" : "OFF");
  if (rm.hasDHT && rm.temp > 0) {
    M5.Display.setTextColor(COL_TEAL);
    M5.Display.setCursor(r.x + pad, cy + 8);
    M5.Display.printf("%.1fC  %.0f%%", rm.temp, rm.humidity);
  }
  if (rm.hasHeat && rm.heatOn) {
    M5.Display.setTextColor(COL_HEAT);
    M5.Display.setCursor(r.x + r.w - 34, cy - 6);
    M5.Display.printf("%.0fC", rm.heatTarget);
  }
  int bx = r.x + pad;
  int by = r.y + CARD_H - 13;
  if (rm.hasWindow) {
    uint16_t wc = rm.windowOpen ? COL_WIND : COL_DARK_GREY;
    M5.Display.fillRect(bx, by, 10, 10, wc);
    M5.Display.setTextColor(rm.windowOpen ? COL_WIND : COL_DARK_GREY);
    M5.Display.setCursor(bx + 12, by + 1);
    M5.Display.print(rm.windowOpen ? "ouv" : "ferm");
    bx += 40;
  }
  if (rm.hasPIR) {
    uint16_t pc = rm.motionDetected ? COL_RED : COL_DARK_GREY;
    M5.Display.fillCircle(bx + 5, by + 5, 5, pc);
  }
  M5.Display.setTextColor(COL_GREY);
  M5.Display.setCursor(r.x + r.w - 12, r.y + CARD_H - 12);
  M5.Display.print(">");
}

