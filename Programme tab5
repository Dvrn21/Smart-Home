// ─── TOPICS ───────────────────────────────────────────────────
String topicLightCmd(int i)     { return "smarthome/lights/"   + String(rooms[i].id) + "/cmd";   }
String topicLightState(int i)   { return "smarthome/lights/"   + String(rooms[i].id) + "/state"; }
String topicDHT(int i)          { return "smarthome/sensors/"  + String(rooms[i].id) + "/dht22"; }
String topicPIR(int i)          { return "smarthome/sensors/"  + String(rooms[i].id) + "/motion";}
String topicShutterCmd(int i)   { return "smarthome/shutters/" + String(rooms[i].id) + "/cmd";   }
String topicShutterState(int i) { return "smarthome/shutters/" + String(rooms[i].id) + "/state"; }
String topicWindowState(int i)  { return "smarthome/windows/"  + String(rooms[i].id) + "/state"; }
String topicHeatCmd(int i)      { return "smarthome/heating/"  + String(rooms[i].id) + "/cmd";   }
String topicHeatState(int i)    { return "smarthome/heating/"  + String(rooms[i].id) + "/state"; }

// ─── MQTT CALLBACK ────────────────────────────────────────────
void mqttCallback(char* topic, byte* payload, unsigned int length) {
  char buf[256];
  unsigned int len = min(length, (unsigned int)(sizeof(buf)-1));
  memcpy(buf, payload, len);
  buf[len] = 0;
  String t = String(topic);
  JsonDocument doc;
  if (deserializeJson(doc, buf) != DeserializationError::Ok) return;

  for (int i = 0; i < NUM_ROOMS; i++) {
    if (t == topicLightState(i)) {
      const char* s = doc["state"] | "";
      if (strcmp(s,"ON")==0)  rooms[i].lightOn = true;
      if (strcmp(s,"OFF")==0) rooms[i].lightOn = false;
      if (doc["brightness"].is<int>()) rooms[i].brightness = doc["brightness"];
      needRedraw = true; return;
    }
    if (t == topicDHT(i)) {
      rooms[i].temp     = doc["temp"]     | 0.0f;
      rooms[i].humidity = doc["humidity"] | 0.0f;
      needRedraw = true; return;
    }
    if (t == topicPIR(i)) {
      if (doc["detected"] | false) {
        rooms[i].motionDetected = true;
        rooms[i].motionLastSeen = millis();
      }
      needRedraw = true; return;
    }
    if (t == topicShutterState(i)) {
      rooms[i].shutterPos    = doc["position"] | rooms[i].shutterPos;
      rooms[i].shutterMoving = doc["moving"]   | false;
      needRedraw = true; return;
    }
    if (t == topicWindowState(i)) {
      const char* s = doc["state"] | "";
      if (strcmp(s,"open")==0)   rooms[i].windowOpen = true;
      if (strcmp(s,"closed")==0) rooms[i].windowOpen = false;
      needRedraw = true; return;
    }
    if (t == topicHeatState(i)) {
      const char* s = doc["state"] | "";
      if (strcmp(s,"ON")==0)  rooms[i].heatOn = true;
      if (strcmp(s,"OFF")==0) rooms[i].heatOn = false;
      if (doc["target"].is<float>()) rooms[i].heatTarget = doc["target"];
      needRedraw = true; return;
    }
  }
}

// ─── MQTT CONNEXION ───────────────────────────────────────────
bool mqttConnect() {
  mqttClient.setServer(MQTT_HOST, MQTT_PORT);
  mqttClient.setCallback(mqttCallback);
  mqttClient.setBufferSize(512);
  mqttClient.setKeepAlive(60);
  String will = "{\"status\":\"offline\",\"client\":\"TAB5_SmartHome\"}";
  bool ok = mqttClient.connect(MQTT_CLIENT, MQTT_USER, MQTT_PASS,
                               "smarthome/status/tab5", 1, true, will.c_str());
  if (ok) {
    mqttClient.subscribe("smarthome/lights/+/state",   1);
    mqttClient.subscribe("smarthome/sensors/+/dht22",  1);
    mqttClient.subscribe("smarthome/sensors/+/motion", 1);
    mqttClient.subscribe("smarthome/shutters/+/state", 1);
    mqttClient.subscribe("smarthome/windows/+/state",  1);
    mqttClient.subscribe("smarthome/heating/+/state",  1);
    mqttClient.publish("smarthome/status/tab5",
      "{\"status\":\"online\",\"client\":\"TAB5_SmartHome\"}", true);
    mqttConnected = true;
  } else {
    mqttConnected = false;
  }
  return ok;
}

// ─── PUBLICATIONS ─────────────────────────────────────────────
void publishLight(int i) {
  if (!mqttClient.connected()) return;
  char buf[128];
  snprintf(buf, sizeof(buf), "{\"state\":\"%s\",\"brightness\":%d,\"src\":\"TAB5\"}",
           rooms[i].lightOn ? "ON" : "OFF", rooms[i].brightness);
  mqttClient.publish(topicLightCmd(i).c_str(), buf, false);
}

void publishShutter(int i) {
  if (!mqttClient.connected() || rooms[i].shutterPos < 0) return;
  char buf[64];
  snprintf(buf, sizeof(buf), "{\"position\":%d,\"src\":\"TAB5\"}", rooms[i].shutterPos);
  mqttClient.publish(topicShutterCmd(i).c_str(), buf, false);
}

void publishHeat(int i) {
  if (!mqttClient.connected() || !rooms[i].hasHeat) return;
  char buf[128];
  snprintf(buf, sizeof(buf), "{\"state\":\"%s\",\"target\":%.1f,\"src\":\"TAB5\"}",
           rooms[i].heatOn ? "ON" : "OFF", rooms[i].heatTarget);
  mqttClient.publish(topicHeatCmd(i).c_str(), buf, false);
}

// ─── LAYOUT ───────────────────────────────────────────────────
void computeLayout() {
  SCR_W  = M5.Display.width();
  SCR_H  = M5.Display.height();
  HDR_H  = max(34, SCR_H * 5 / 100);
  GAP    = max(3, SCR_W / 160);
  CARD_W = (SCR_W - GAP * 5) / 4;
  CARD_H = (SCR_H - HDR_H - GAP * 3) / 2;
  for (int i = 0; i < NUM_ROOMS; i++) {
    int col = i % 4, row = i / 4;
    cardRects[i] = {
      GAP + col * (CARD_W + GAP),
      HDR_H + GAP + row * (CARD_H + GAP),
      CARD_W, CARD_H
    };
  }
}

