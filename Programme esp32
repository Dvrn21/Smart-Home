void handleRoot() { server.send_P(200, "text/html", PAGE); }
 
void handleData() {
  float h; int dow, yday; heureSim(h, dow, yday);
  String j = "{";
  j += "\"motion\":" + String(lastMotion);
  j += ",\"temp\":" + String(lastTemp, 1);
  j += ",\"hum\":" + String(lastHum, 1);
  j += ",\"heure\":" + String(h, 1);
  j += ",\"weekend\":" + String((dow == 0 || dow == 6) ? 1 : 0);
  j += ",\"mqtt\":" + String(mqtt.connected() ? 1 : 0);
  j += "}";
  server.send(200, "application/json", j);
}
 
void handleHour() {
  if (server.hasArg("h")) {
    String h = server.arg("h");
    if (h == "auto") { heureForcee = -1; }
    else { int v = h.toInt(); if (v >= 0 && v <= 23) heureForcee = v; }
  }
  server.send(200, "text/plain", "ok");
}
 
// ============================================================
//  CONTROLE DEMO via Moniteur Serie
// ============================================================
void lireCommandeDemo() {
  if (!Serial.available()) return;
  String s = Serial.readStringUntil('\n'); s.trim();
  if (s.equalsIgnoreCase("auto")) { heureForcee = -1; Serial.println("Heure : AUTO"); }
  else if (s.length()) {
    int v = s.toInt();
    if (v >= 0 && v <= 23) { heureForcee = v; Serial.printf("Heure forcee : %dh\n", v); }
  }
}
 
// ============================================================
//  SETUP / LOOP
// ============================================================
void setup() {
  Serial.begin(115200);
  pinMode(LED_LUMIERE, OUTPUT);
  pinMode(LED_CAFE, OUTPUT);
  pinMode(LED_REVEIL, OUTPUT);
  pinMode(PIN_BUZZER, OUTPUT);
  pinMode(LED_STATUS, OUTPUT);
  digitalWrite(LED_LUMIERE, LOW);
  digitalWrite(LED_CAFE, LOW);
  digitalWrite(LED_REVEIL, LOW);
  randomSeed(esp_random());
 
  tTemp    = "smarthome/" + String(PIECE) + "/temperature";
  tHum     = "smarthome/" + String(PIECE) + "/humidity";
  tMotion  = "smarthome/" + String(PIECE) + "/motion";
  tPred    = "smarthome/predictions/" + String(PIECE);
  tCmdBase = "smarthome/" + String(PIECE) + "/cmd/";
 
  WiFi.mode(WIFI_STA);
  WiFi.begin(WIFI_SSID, WIFI_PASS);
  Serial.print("WiFi ");
  while (WiFi.status() != WL_CONNECTED) { delay(400); Serial.print("."); }
  Serial.printf(" OK : %s\n", WiFi.localIP().toString().c_str());
  configTzTime(TZ_FRANCE, "pool.ntp.org");
 
  netSecure.setInsecure();
  mqtt.setServer(MQTT_HOST, MQTT_PORT);
  mqtt.setCallback(onMqtt);
  mqtt.setBufferSize(512);
 
  server.on("/", handleRoot);
  server.on("/data", handleData);
  server.on("/hour", handleHour);
  server.begin();
  Serial.printf("Dashboard web : http://%s\n", WiFi.localIP().toString().c_str());
 
  Serial.println("\n=== ESP CUISINE (sim + Tab5 + web) ===");
}
 
void loop() {
  if (!mqtt.connected()) reconnecterMqtt();
  mqtt.loop();
  server.handleClient();
  lireCommandeDemo();
  digitalWrite(LED_STATUS, mqtt.connected() ? HIGH : LOW);
 
  unsigned long now = millis();
  if (cafeOffAt   && now > cafeOffAt)   { digitalWrite(LED_CAFE, LOW);   cafeOffAt = 0; }
  if (reveilOffAt && now > reveilOffAt) { digitalWrite(LED_REVEIL, LOW); reveilOffAt = 0; }
 
  if (now - lastPub >= INTERVALLE) {
    lastPub = now;
    publierSimulation();
  }
}
