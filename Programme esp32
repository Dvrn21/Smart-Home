int   lastMotion = 0;
float lastTemp = 0, lastHum = 0, lastHeure = 0;
bool  lastWeekend = false;
 
// ============================================================
//  HORLOGE (reelle ou forcee)
// ============================================================
void heureSim(float &h, int &dow, int &yday) {
  struct tm t;
  if (getLocalTime(&t)) {
    dow = t.tm_wday; yday = t.tm_yday;
    h = (heureForcee >= 0) ? (float)heureForcee : t.tm_hour + t.tm_min / 60.0f;
  } else {
    dow = 1; yday = 0; h = (heureForcee >= 0) ? heureForcee : 12;
  }
}
 
// ============================================================
//  ACTIONNEURS / LEDs
// ============================================================
void allumerLumiere(bool on) {
  lumiereOn = on;
  digitalWrite(LED_LUMIERE, on ? HIGH : LOW);
  Serial.printf(">> Lumiere %s\n", on ? "ON" : "OFF");
}
void pulseCafe() {
  digitalWrite(LED_CAFE, HIGH);
  cafeOffAt = millis() + PULSE_MS;
  Serial.println(">> Cafe");
}
void pulseReveil() {
  digitalWrite(LED_REVEIL, HIGH);
  reveilOffAt = millis() + PULSE_MS;
  tone(PIN_BUZZER, 1000, 300);
  Serial.println(">> Reveil");
}
 
// ============================================================
//  SIMULATION DES CAPTEURS (profil cuisine)
// ============================================================
float bruit(float ecart) { return (random(-1000, 1000) / 1000.0f) * ecart; }
 
int simulerMotion(float h, bool weekend) {
  const float prof[][3] = {{7, 9, 0.8}, {12, 13, 0.6}, {19, 21, 0.8}};
  float shift = weekend ? 1.5f : 0.0f;
  float p = 0.03f;
  for (auto &pr : prof)
    if ((pr[0] + shift) <= h && h < (pr[1] + shift)) p = pr[2];
  return (random(0, 1000) / 1000.0f < p) ? 1 : 0;
}
float simulerTemperature(float h) {
  return 20.0f + 2.5f * sinf((h - 15) / 24.0f * 2 * PI) + bruit(0.3f);
}
float simulerHumidite(float h) {
  return 55.0f - 5.0f * sinf((h - 15) / 24.0f * 2 * PI) + bruit(1.5f);
}
 
// ============================================================
//  MQTT - reception (commandes Tab5 OU predictions IA)
// ============================================================
void onMqtt(char* topic, byte* payload, unsigned int len) {
  String t = String(topic);
  if (t.startsWith(tCmdBase)) {
    bool on = (len > 0 && payload[0] == '1');
    if      (t.endsWith("/lumiere")) allumerLumiere(on);
    else if (t.endsWith("/cafe")   && on) pulseCafe();
    else if (t.endsWith("/reveil") && on) pulseReveil();
    return;
  }
  StaticJsonDocument<128> doc;
  if (deserializeJson(doc, payload, len)) return;
  float prob = doc["activity_prob"] | 0.0f;
  Serial.printf("Prediction cuisine : activity_prob=%.2f\n", prob);
  bool actif = (prob >= SEUIL_PRESENCE);
  allumerLumiere(actif);
  float h; int dow, yday; heureSim(h, dow, yday);
  if (h >= 6 && h < 9 && actif && yday != dernierJourCafe) {
    pulseCafe(); pulseReveil(); dernierJourCafe = yday;
  }
}
 
void reconnecterMqtt() {
  while (!mqtt.connected()) {
    Serial.print("MQTT TLS ... ");
    if (mqtt.connect("esp-cuisine", MQTT_USER, MQTT_PASS)) {
      Serial.println("OK");
      mqtt.subscribe((tCmdBase + "#").c_str(), 1);
      mqtt.subscribe(tPred.c_str(), 1);
      Serial.println("Abonne aux commandes Tab5 + predictions");
    } else {
      Serial.printf("echec rc=%d, retry 3s\n", mqtt.state());
      delay(3000);
    }
  }
}
 
void publierSimulation() {
  float h; int dow, yday; heureSim(h, dow, yday);
  bool weekend = (dow == 0 || dow == 6);
  int   motion = simulerMotion(h, weekend);
  float temp   = simulerTemperature(h);
  float hum    = simulerHumidite(h);
 
  mqtt.publish(tMotion.c_str(), motion ? "1" : "0");
  mqtt.publish(tTemp.c_str(),   String(temp, 1).c_str());
  mqtt.publish(tHum.c_str(),    String(hum, 1).c_str());
 
  lastMotion = motion; lastTemp = temp; lastHum = hum;
  lastHeure = h; lastWeekend = weekend;
 
  Serial.printf("[SIM] h=%.1f %s motion=%d temp=%.1f hum=%.1f\n",
                h, weekend ? "(we)" : "", motion, temp, hum);
}
 
